APP_NAME=SachmeBot
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Tehran
APP_URL=https://bot.sachme.net

LOG_CHANNEL=single
LOG_LEVEL=info

# پیش‌فرض: database/database.sqlite . برای مسیر دیگر DB_DATABASE را مطلق بده.
DB_CONNECTION=sqlite
# DB_DATABASE=/home/sachmene/laravel/database/database.sqlite

# state گفت‌وگو و کش روی فایل (نیازی به جدول دیتابیس ندارد)
CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

# ---- تنظیمات ربات ----
BOT_TOKEN=
WEBHOOK_URL=https://bot.sachme.net
TELEGRAM_CHANNEL=@sachme_kaf
# آیدی عددی ادمین‌ها با کاما
TELEGRAM_ADMINS=271469412
